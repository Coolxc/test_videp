# DeepSeek API 配置
# API Key（必填，否则降级到静态模版）
DEEPSEEK_API_KEY=your_api_key_here
# 模型名称（可选，官方支持: deepseek-v4-flash / deepseek-v4-pro / deepseek-chat / deepseek-reasoner）
DEEPSEEK_MODEL=deepseek-v4-flash
# API 地址（可选，默认官方地址）
# DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# Tencent Cloud TTS credentials (required for --mode full)
TENCENT_SECRET_ID=your_secret_id_here
TENCENT_SECRET_KEY=your_secret_key_here
TENCENT_TTS_VOICE_TYPE=602005
TENCENT_TTS_SPEED=1.1
